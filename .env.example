# llmmllab-runner local development configuration

# Logging
LOG_LEVEL=INFO

# llama.cpp binary path
LLAMA_SERVER_EXECUTABLE=

# Path to models.yaml (model definitions)
MODELS_FILE_PATH=./models.local.yaml

# Cache timeout (minutes): server becomes *eligible* for eviction when VRAM
# pressure occurs, once idle for this long. Soft limit.
CACHE_TIMEOUT_MIN=30

# Eviction timeout (minutes): server *must* be evicted once idle for this long,
# regardless of VRAM pressure. Hard limit.
EVICTION_TIMEOUT_MIN=60

# Network
RUNNER_PORT=8000
RUNNER_HOST=0.0.0.0

# Dynamic port range for llama.cpp server instances
SERVER_PORT_RANGE_START=8001
SERVER_PORT_RANGE_END=8900

# Persistent KV cache slot directory (leave empty to disable).
# When set, passes --slot-save-path to llama-server so conversation
# state can be saved/restored via the slot save/restore API.
# SLOT_SAVE_DIR=/data/slots

# When SLOT_SAVE_DIR is set, also pass --no-mmap (default: true).
# Prevents OS from evicting mmap pages between save and restore.
# SLOT_NO_MMAP=true

# When SLOT_SAVE_DIR is set, also pass --swa-full (default: true).
# Required for SWA models (e.g. Qwen 3.5) to correctly persist KV cache.
# SLOT_SWA_FULL=true
